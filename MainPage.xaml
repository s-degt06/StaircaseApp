<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Maui3DApp.MainPage"
             BackgroundColor="White">

    <Grid RowDefinitions="Auto,*,Auto" Padding="10">

        <!-- Панель управления -->
        <VerticalStackLayout Spacing="10">

            <!-- Размеры и количество фигур -->
            <Grid ColumnDefinitions="Auto,*,Auto"
                  RowDefinitions="Auto,Auto,Auto,Auto"
                  ColumnSpacing="10"
                  RowSpacing="10">

                <Label Text="Width"/>
                <Slider x:Name="WidthSlider" Grid.Column="1" Minimum="0.5" Maximum="5" Value="2"/>
                <Entry x:Name="WidthEntry" Grid.Column="2" Keyboard="Numeric"/>

                <Label Text="Height" Grid.Row="1"/>
                <Slider x:Name="HeightSlider" Grid.Row="1" Grid.Column="1" Minimum="0.5" Maximum="5" Value="1"/>
                <Entry x:Name="HeightEntry" Grid.Row="1" Grid.Column="2" Keyboard="Numeric"/>

                <Label Text="Depth" Grid.Row="2"/>
                <Slider x:Name="DepthSlider" Grid.Row="2" Grid.Column="1" Minimum="0.5" Maximum="5" Value="1"/>
                <Entry x:Name="DepthEntry" Grid.Row="2" Grid.Column="2" Keyboard="Numeric"/>

                <Label Text="Count" Grid.Row="3"/>
                <Entry x:Name="CountEntry" Grid.Row="3" Grid.Column="1" Keyboard="Numeric" Text="1"/>
            </Grid>
        </VerticalStackLayout>

        <!-- WebView -->
        <WebView x:Name="WebView3D"
                 Grid.Row="1"
                 HeightRequest="400"/>
    </Grid>
</ContentPage>

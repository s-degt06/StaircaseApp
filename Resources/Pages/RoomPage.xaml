<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Maui3DApp.Pages.RoomPage"
             Title="Расчёт помещения"
             BackgroundColor="White">

    <VerticalStackLayout Spacing="16" Padding="24" VerticalOptions="Center">

        <Label Text="Параметры помещения" FontSize="18" FontAttributes="Bold"/>

        <Grid ColumnDefinitions="80,*"
              RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto"
              ColumnSpacing="12" RowSpacing="12">

            <Label Text="A (мм)"  VerticalOptions="Center"/>
            <Entry x:Name="AEntry" Grid.Column="1" Keyboard="Numeric" Placeholder="напр. 2750"/>

            <Label Text="B (мм)"  Grid.Row="1" VerticalOptions="Center"/>
            <Entry x:Name="BEntry" Grid.Row="1" Grid.Column="1" Keyboard="Numeric" Placeholder="напр. 1800"/>

            <Label Text="C (мм)"  Grid.Row="2" VerticalOptions="Center"/>
            <Entry x:Name="CEntry" Grid.Row="2" Grid.Column="1" Keyboard="Numeric" Placeholder="напр. 3000"/>

            <Label Text="h1 (мм)" Grid.Row="3" VerticalOptions="Center"/>
            <Entry x:Name="H1Entry" Grid.Row="3" Grid.Column="1" Keyboard="Numeric" Placeholder="высота 1"/>

            <Label Text="h2 (мм)" Grid.Row="4" VerticalOptions="Center"/>
            <Entry x:Name="H2Entry" Grid.Row="4" Grid.Column="1" Keyboard="Numeric" Placeholder="высота 2"/>

            <Label Text="N (шт)"  Grid.Row="5" VerticalOptions="Center"/>
            <Entry x:Name="NEntry" Grid.Row="5" Grid.Column="1" Keyboard="Numeric" Placeholder="кол-во ступеней"/>

        </Grid>

        <Label x:Name="ErrorLabel"
               TextColor="Red"
               IsVisible="False"/>

        <Button Text="Рассчитать"
                Clicked="OnCalculateClicked"/>

    </VerticalStackLayout>
</ContentPage>